{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [
      "dom",
    ],
    "module": "CommonJS",
    "strict": true,
    "noEmit": true,
    "types": [
      "node",
      "jest"
    ],
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true
  },
  "include": [
    "src/**/*"
  ],
  "exclude": [
    "node_modules"
  ],
  "typeRoots": [
    "node_modules/@types"
  ]
}
